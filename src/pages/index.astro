---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

type DataWithFeaturedImage = {
	featured_image?: unknown;
	featuredImage?: unknown;
};

const getFeaturedImage = (data: DataWithFeaturedImage) =>
	data.featured_image ?? data.featuredImage;

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const postsWithMeta = await Promise.all(
	sortedPosts.map(async (post) => {
		const [tags, categories] = await Promise.all([
			getEntryTerms("posts", post.data.id, "tag"),
			getEntryTerms("posts", post.data.id, "category"),
		]);

		return {
			post,
			tags: tags.map((tag) => ({ slug: tag.slug, label: tag.label })),
			categories: categories.map((category) => ({ slug: category.slug, label: category.label })),
			bylines: post.data.bylines ?? [],
			readingTime: getReadingTime(post.data.content),
		};
	})
);

const leadStory = postsWithMeta[0] ?? null;
const sideStories = postsWithMeta.slice(1, 3);
const columnStories = postsWithMeta.slice(3, 6);
const archiveStories = postsWithMeta.slice(6);
const settings = await getSiteSettings();
const siteTitle = settings.title || "Field Notes";
const siteTagline = settings.tagline || "Notes on software, design, and independent work";
const formatDate = (date: Date | null | undefined) =>
	date
		? date.toLocaleDateString("en-US", {
				month: "long",
				day: "numeric",
				year: "numeric",
			})
		: null;
---

<Base title="Home" description={siteTagline}>
	{
		postsWithMeta.length === 0 ? (
			<section class="empty-state">
				<h2>No posts yet</h2>
				<p>Create your first post in the admin panel.</p>
				<a href="/_emdash/admin/content/posts/new" class="btn">Create a post</a>
			</section>
		) : (
			<div class="home-content">
				<section class="home-intro">
					<p class="eyebrow">Personal publication</p>
					<h1 class="home-title">{siteTitle}</h1>
					<p class="home-summary">{siteTagline}</p>
				</section>

				<section class="lead-grid">
					{leadStory && (
						<div class="lead-story">
							{leadStory.categories[0] && (
								<a href={`/category/${leadStory.categories[0].slug}`} class="story-kicker">
									{leadStory.categories[0].label}
								</a>
							)}
							<PostCard
								variant="feature"
								title={leadStory.post.data.title ?? "Untitled"}
								excerpt={leadStory.post.data.excerpt}
								featuredImage={getFeaturedImage(leadStory.post.data)}
								href={`/posts/${leadStory.post.id}`}
								date={leadStory.post.data.publishedAt ?? undefined}
								readingTime={leadStory.readingTime}
								tags={leadStory.tags}
								bylines={leadStory.bylines}
							/>
						</div>
					)}

					<aside class="supporting-rail">
						{sideStories.map((story) => (
							<div class="supporting-story">
								{story.categories[0] && (
									<a href={`/category/${story.categories[0].slug}`} class="story-kicker">
										{story.categories[0].label}
									</a>
								)}
								<PostCard
									variant="compact"
									title={story.post.data.title ?? "Untitled"}
									excerpt={story.post.data.excerpt}
									featuredImage={getFeaturedImage(story.post.data)}
									href={`/posts/${story.post.id}`}
									date={story.post.data.publishedAt ?? undefined}
									readingTime={story.readingTime}
									tags={story.tags}
									bylines={story.bylines}
									showImage={false}
								/>
							</div>
						))}
					</aside>
				</section>

				{columnStories.length > 0 && (
					<section class="news-row">
						<header class="section-header">
							<h2 class="section-title">Latest writing</h2>
							<a href="/posts" class="section-link">Browse all</a>
						</header>
						<div class="news-columns">
							{columnStories.map((story) => (
								<div class="news-column">
									{story.categories[0] && (
										<a href={`/category/${story.categories[0].slug}`} class="story-kicker">
											{story.categories[0].label}
										</a>
									)}
									<PostCard
										variant="secondary"
										title={story.post.data.title ?? "Untitled"}
										excerpt={story.post.data.excerpt}
										featuredImage={getFeaturedImage(story.post.data)}
										href={`/posts/${story.post.id}`}
										date={story.post.data.publishedAt ?? undefined}
										readingTime={story.readingTime}
										tags={story.tags}
										bylines={story.bylines}
									/>
								</div>
							))}
						</div>
					</section>
				)}

				{archiveStories.length > 0 && (
					<section class="archive-section">
						<header class="section-header">
							<h2 class="section-title">More from the archive</h2>
						</header>
						<div class="archive-list">
							{archiveStories.map((story) => (
								<article class="archive-item">
									<div class="archive-meta">
										{story.categories[0] && (
											<a href={`/category/${story.categories[0].slug}`} class="story-kicker">
												{story.categories[0].label}
											</a>
										)}
										{formatDate(story.post.data.publishedAt) && (
											<time>{formatDate(story.post.data.publishedAt)}</time>
										)}
									</div>
									<h3 class="archive-title">
										<a href={`/posts/${story.post.id}`}>{story.post.data.title}</a>
									</h3>
									{story.post.data.excerpt && <p class="archive-excerpt">{story.post.data.excerpt}</p>}
								</article>
							))}
						</div>
					</section>
				)}
			</div>
		)
	}
</Base>

<style>
	.home-content {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6) var(--spacing-16);
	}

	.home-intro {
		max-width: 720px;
		margin-bottom: var(--spacing-12);
	}

	.eyebrow,
	.story-kicker,
	.section-title,
	.archive-meta {
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.story-kicker {
		display: inline-block;
		margin-bottom: var(--spacing-3);
	}

	.home-title {
		font-family: var(--font-serif);
		font-size: clamp(2.5rem, 5vw, 5rem);
		line-height: 0.95;
		letter-spacing: -0.045em;
		max-width: 14ch;
		margin: var(--spacing-3) 0 var(--spacing-4);
	}

	.home-summary {
		max-width: 60ch;
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.lead-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
		gap: var(--spacing-8);
		padding-bottom: var(--spacing-12);
		border-bottom: 1px solid var(--color-border);
	}

	.supporting-rail {
		display: grid;
		align-content: start;
	}

	.supporting-story + .supporting-story {
		margin-top: var(--spacing-8);
	}

	.news-row,
	.archive-section {
		margin-top: var(--spacing-12);
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: var(--spacing-4);
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--spacing-8);
	}

	.section-link {
		font-size: var(--font-size-sm);
		color: var(--color-accent);
	}

	.news-columns {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--spacing-6);
	}

	.news-column {
		padding-left: var(--spacing-6);
		border-left: 1px solid var(--color-border-subtle);
	}

	.news-column:first-child {
		padding-left: 0;
		border-left: none;
	}

	.archive-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--spacing-8) var(--spacing-10);
	}

	.archive-item {
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	.archive-meta {
		display: flex;
		gap: var(--spacing-3);
		flex-wrap: wrap;
		margin-bottom: var(--spacing-3);
	}

	.archive-title {
		font-family: var(--font-serif);
		font-size: clamp(1.4rem, 2vw, 2rem);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-3);
	}

	.archive-title a {
		color: var(--color-text);
	}

	.archive-title a:hover {
		color: var(--color-accent);
	}

	.archive-excerpt {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-3);
		text-align: center;
		padding: var(--spacing-20) var(--spacing-6);
		max-width: 420px;
		margin: 0 auto;
	}

	.empty-state h2 {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
	}

	.empty-state p {
		color: var(--color-muted);
	}

	.btn {
		display: inline-block;
		margin-top: var(--spacing-4);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		border-radius: 999px;
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	.btn:hover {
		background: var(--color-accent-hover);
	}

	@media (max-width: 980px) {
		.lead-grid,
		.news-columns,
		.archive-list {
			grid-template-columns: 1fr;
		}

		.news-column {
			padding-left: 0;
			border-left: none;
		}

		.supporting-story + .supporting-story {
			margin-top: var(--spacing-6);
		}
	}

	@media (max-width: 640px) {
		.home-content {
			padding: var(--spacing-8) var(--spacing-4) var(--spacing-12);
		}

		.home-title {
			font-size: 2.6rem;
		}

		.section-header {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
