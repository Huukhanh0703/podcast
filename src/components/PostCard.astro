---
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
	variant?: "feature" | "secondary" | "compact";
	showImage?: boolean;
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags = [],
	bylines = [],
	variant = "secondary",
	showImage = true,
} = Astro.props;

type ImageLike = {
	id?: string;
	src?: string;
	alt?: string;
	meta?: {
		storageKey?: string | null;
	};
};

function normalizeFeaturedImage(
	image: MediaValue | string | undefined,
	fallbackAlt: string
): ImageLike | undefined {
	if (!image) return undefined;

	if (typeof image === "string") {
		return { src: image, alt: fallbackAlt };
	}

	const candidate = image as ImageLike;
	if (candidate.src) return candidate;

	const storageKey = candidate.meta?.storageKey || candidate.id;
	if (!storageKey) return undefined;

	return {
		...candidate,
		src: `/_emdash/api/media/file/${storageKey}`,
		alt: candidate.alt || fallbackAlt,
	};
}

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	: null;

const normalizedFeaturedImage = normalizeFeaturedImage(featuredImage, title);
const hasImage = showImage && !!normalizedFeaturedImage;
const visibleTags = variant === "compact" ? tags.slice(0, 1) : tags.slice(0, 2);
const TitleTag = variant === "feature" ? "h2" : "h3";
---

<article class:list={["post-card", `post-card--${variant}`]}>
	<a href={href} class="card-link">
		{
			hasImage && (
				<div class="card-image">
					<Image image={normalizedFeaturedImage!} />
				</div>
			)
		}
		<div class="card-body">
			<div class="card-meta">
				{
					bylines.length > 0 && (
						<>
							<div class="card-bylines">
								{bylines.slice(0, 1).map((credit) => (
									<span class="card-byline">
										{credit.byline.avatarMediaId && (
											<img
												src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
												alt={credit.byline.displayName}
												class="card-byline-avatar"
											/>
										)}
										<span class="card-byline-name">{credit.byline.displayName}</span>
									</span>
								))}
								{bylines.length > 1 && <span class="byline-more">+{bylines.length - 1}</span>}
							</div>
							{(formattedDate || readingTime) && <span class="meta-dot" />}
						</>
					)
				}
				{formattedDate && <time>{formattedDate}</time>}
				{formattedDate && readingTime && <span class="meta-dot" />}
				{readingTime && <span>{readingTime} min read</span>}
			</div>
			<TitleTag class="card-title">{title}</TitleTag>
			{excerpt && <p class="card-excerpt">{excerpt}</p>}
		</div>
	</a>
	{
		visibleTags.length > 0 && (
			<div class="card-tags">
				{visibleTags.map((tag) => (
					<a href={`/tag/${tag.slug}`} class="card-tag">
						{tag.label}
					</a>
				))}
			</div>
		)
	}
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.post-card--feature {
		padding-top: 0;
		border-top: none;
	}

	.card-link {
		display: grid;
		gap: var(--spacing-4);
		color: inherit;
	}

	.post-card--compact .card-link {
		gap: var(--spacing-3);
	}

	.card-image {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--color-surface);
	}

	.post-card--feature .card-image {
		aspect-ratio: 16 / 11;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.card-link:hover .card-image img {
		transform: scale(1.02);
	}

	.card-body {
		display: grid;
		gap: var(--spacing-2);
	}

	.card-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		column-gap: var(--spacing-2);
		row-gap: var(--spacing-1);
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.card-bylines {
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.card-byline {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-1);
	}

	.card-byline-avatar {
		width: var(--avatar-size-xs);
		height: var(--avatar-size-xs);
		border-radius: 50%;
		object-fit: cover;
	}

	.card-byline-name {
		font-weight: 500;
		color: var(--color-text-secondary);
		letter-spacing: normal;
		text-transform: none;
	}

	.byline-more {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		letter-spacing: normal;
		text-transform: none;
	}

	.meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
	}

	.card-title {
		font-family: var(--font-serif);
		font-size: clamp(1.55rem, 2vw, 2.2rem);
		font-weight: 700;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		transition: color var(--transition-fast);
	}

	.post-card--compact .card-title {
		font-size: clamp(1.2rem, 1.7vw, 1.55rem);
	}

	.post-card--feature .card-title {
		font-size: clamp(2rem, 3vw, 3rem);
	}

	.card-link:hover .card-title {
		color: var(--color-accent);
	}

	.card-excerpt {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card--compact .card-excerpt {
		-webkit-line-clamp: 2;
		font-size: var(--font-size-sm);
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}

	.card-tag {
		display: inline-block;
		padding: var(--tag-padding-y) var(--spacing-2);
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
		border-radius: 999px;
	}

	.card-tag:hover {
		color: var(--color-text);
		border-color: var(--color-text-secondary);
	}
</style>
